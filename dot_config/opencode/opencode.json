{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "coworker",
    "theme": "nord",
    "lsp": true,
    "permission": {
        "bash": {
            "*": "ask",

            "*npm *": "allow",
            "*npx *": "allow",
            "*node *": "allow",
            "*bazel build *": "allow",
            "*bazel test *": "allow",
            "*bun *": "allow",
            "*cargo *": "allow",
            "go *": "allow",
            "*rustfmt *": "allow",
            "*make *": "allow",
            "*gofmt *": "allow",
            "*golangci-lint run *": "allow",

            "*mkdir *": "allow",
            "*grep *": "allow",
            "*echo *": "allow",
            "*rg *": "allow",
            "*ls *": "allow",
            "*cat *": "allow",
            "*head *": "allow",
            "*tail *": "allow",
            "*tee *": "allow",
            "*sort *": "allow",
            "*find *": "allow",
            "*wc *": "allow",
            "*which *": "allow",
            "*sed *": "allow",
            "*grep *": "allow",

            "*git status *": "allow",
            "*git branch *": "allow",
            "*git log *": "allow",
            "*git diff *": "allow",
            "*git show *": "allow",
            "*git branch -?": "allow",
            "*git remote *": "allow",
            "*git rev-parse *": "allow",
            "*git worktree *": "allow",
            "*git config --get *": "allow",
            "*git merge-base *": "allow",
            "*git symbolic-ref *": "allow",

            "*git-default-branch*": "allow",

            "*gh pr view *": "allow",
            "*gh pr diff *": "allow",

            "*gcloud logging read*": "allow",
            "*gcx metrics query*": "allow"
        },
        "external_directory": {
            "~/.cargo/**": "allow",
            "~/go/pkg/mod/**": "allow",
            "~/Documents/projects/**": "allow",
            "/tmp/**": "allow"
        }
    }
}
